# ── Required ────────────────────────────────────────────────────────────────
# Async PostgreSQL connection string (TimescaleDB + pgvector via docker-compose)
DATABASE_URL=postgresql+asyncpg://edgar:edgar@localhost:5432/edgar_db

# SEC EDGAR fair-use identification header — required, no default.
# Format: AppName/Version your-email@domain.com
SEC_USER_AGENT=EdgarPlatform/1.0 your-email@domain.com

# ── LLM (at least one required to use the /ask endpoint) ────────────────────
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Optional — safe defaults are already set ────────────────────────────────
# REDIS_URL=redis://localhost:6379
# SEC_REQUESTS_PER_SECOND=8
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# SP500_ONLY=true
# MAX_WORKERS=4
